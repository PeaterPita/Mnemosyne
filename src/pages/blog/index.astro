---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import { constellations } from "../../data/constellations";
import ConstellationList from "../../components/ConstellationList.astro";
import BlogCard from "../../components/BlogCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import FilterBar from "../../components/FilterBar.astro";

const blogs = await getCollection("blogs");

const tags = blogs
    .flatMap((blog) => blog.data.tags)
    .reduce((accumulated, tag) => {
        accumulated[tag] = (accumulated[tag] || 0) + 1;
        return accumulated;
    }, {});

const grouped = constellations.map((constellation) => ({
    constellation,
    blogs: blogs
        .filter((blog) => blog.data.constellation === constellation.name)
        .sort((a, b) => +b.data.date - +a.data.date),
}));
---

<MainLayout title="The Archives">
    <main>
        <a href="/"> &larr; Return to the observatory</a>

        <SectionHeader
            title="The Archives"
            kicker=`THE COMPLETE CATALOGUE - ${blogs.length} STARS RECORDED`
        />

        <FilterBar {tags} />

        <div class="grid">
            {
                grouped.map(({ constellation, blogs }) => (
                    <ConstellationList {constellation}>
                        {blogs.map((blog) => (
                            <BlogCard {blog} />
                        ))}
                    </ConstellationList>
                ))
            }
        </div>
    </main>
</MainLayout>

<style>
    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(min(400px, 100%), 1fr));
        gap: 2rem;
        align-items: start;
    }
</style>

<script>
    const tagButtons = [...document.querySelectorAll("[data-tag]")];
    const blogs = [...document.querySelectorAll<HTMLElement>("[data-post]")];

    const active = new Set<string>();

    function apply() {
        for (const blog of blogs) {
            console.log(blog.dataset.tags);
            const tags = (blog.dataset.tags ?? "").split(" ").filter(Boolean);
            const show =
                active.size === 0 || [...active].some((t) => tags.includes(t));
            blog.hidden = !show;
        }
    }

    for (const btn of tagButtons) {
        btn.addEventListener("click", () => {
            const tag = btn.dataset.tag ?? "";
            active.has(tag) ? active.delete(tag) : active.add(tag);
            btn.setAttribute("aria-pressed", String(active.has(tag)));
            apply();
        });
    }
</script>
