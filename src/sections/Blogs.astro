---
import { getCollection } from "astro:content";
import { dateFormat } from "../utils.ts";
import SectionHeader from "../components/SectionHeader.astro";

const blogs = (await getCollection("blogs"))
    .sort((a, b) => +b.data.date - +a.data.date)
    .slice(0, 5);
---

<section>
    <SectionHeader kicker="The Archives" title="Recent Entries" />

    <ol class="blog-entries">
        {
            blogs.map((blog) => (
                <li>
                    <a href={`/blog/${blog.id}`} class="entry">
                        <div class="entry-body">
                            <div class="entry-meta">
                                <time datetime={blog.data.date.toISOString()}>
                                    {dateFormat(blog.data.date)}
                                </time>
                                <div class="entry-tags">
                                    {blog.data.tags.map((tag) => (
                                        <span class="tag">{tag}</span>
                                    ))}
                                </div>
                            </div>
                            <span class="entry-title">{blog.data.title}</span>
                            <span class="entry-description">
                                {blog.data.description}
                            </span>
                        </div>
                        <span class="entry-arrow">&rarr;</span>
                    </a>
                </li>
            ))
        }
    </ol>

    <p class="more">
        <a href="/blog/">Browse the complete archives &rarr;</a>
    </p>
</section>

<style>
    .blog-entries {
        list-style: none;
        border-top: 1px solid var(--line);
    }

    .entry {
        display: flex;
        align-items: baseline;
        gap: 1.2rem;
        padding: 1.5rem 0.6rem;
        border-bottom: 1px solid var(--line);
        align-items: center;
        text-decoration: none;
        transition: background 0.2s ease;
    }

    .entry:hover {
        /* background: rgba(201, 163, 92, 0.04); */
        background: rgb(from var(--accent-light) r g b / 0.1);
    }

    .entry-body {
        flex: 1;
    }

    .entry-meta {
        display: flex;
        gap: 2rem;
        align-items: center;
        margin-bottom: 0.6rem;
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        color: var(--muted);
    }

    .entry-title {
        display: block;
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--text);
        line-height: 1.25;
        margin: 0.35rem;
    }

    .entry-description {
        display: block;
        color: var(--muted);
    }

    .entry-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .tag {
        color: var(--text);
        font-size: 0.6rem;
        border-radius: 30%;
        border: 1px solid var(--accent);
        background-color: rgb(from var(--accent-light) r g b / 0.15);
        padding: 0.4rem;

        transition: all 0.3 ease-in-out;
    }

    .tag:hover {
        background-color: rgb(from var(--accent-light) r g b / 0.3);
    }

    .entry-arrow {
        color: var(--accent);
        flex-shrink: 0;
        font-size: 1.8rem;

        transition: all 0.3s ease;
    }

    .entry:hover .entry-title {
        color: #fff;
    }

    .entry:hover .entry-arrow {
        color: var(--accent-lgiht);
        transform: translateX(5px);
    }

    .more {
        margin-top: 2rem;
        font-size: 0.8rem;
    }
</style>
