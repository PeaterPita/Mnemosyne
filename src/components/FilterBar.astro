---
const { tags } = Astro.props;
---

<div class="filter-bar">
    {
        Object.entries(tags).map(([tag, count]) => (
            <button
                type="button"
                class="tag-button"
                data-tag={tag}
                aria-pressed="false"
            >
                {tag} | {count}
            </button>
        ))
    }
</div>

<style>
    .filter-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .tag-button {
        color: var(--text);
        font-size: 0.6rem;
        padding: 0.4rem 0.9rem;
        background: rgb(from var(--accent-light) r g b / 0.09);
        border: 1px solid var(--line);
        border-radius: 100px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .tag-button:hover {
        border-color: var(--accent);
    }

    .tag-button[aria-pressed="true"] {
        color: var(--primary);
        font-weight: 600;
        background: var(--accent);
        border-color: var(--accent-light);
    }
</style>
