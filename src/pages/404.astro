---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="404 - Uncharted">
    <main class="content">
        <p class="kicker">OBSERVATION FAILED</p>
        <h1>404</h1>
        <p class="error">
            This region of the star system is uncharted. Please return back!
        </p>
        <a class="home" href="/">&larr; return to the observatory</a>
    </main>
</MainLayout>

<style>
    .content {
        height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 2rem;
    }

    .kicker {
        font-size: 0.6rem;
        letter-spacing: 0.36em;
        color: var(--accent);
    }

    h1 {
        font-size: clamp(5rem, 18vw, 10rem);
        line-height: 1;
        margin: 0.5rem;
    }

    .error {
        max-width: 60%;
        font-style: italic;
        color: var(--muted);
        margin-bottom: 2rem;
    }
</style>
