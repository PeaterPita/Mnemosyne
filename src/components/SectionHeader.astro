---
interface Props {
    kicker: string;
    title: string;
}

const { title, kicker } = Astro.props;
---

<header style="margin-bottom:3.5rem">
    <p class="kicker">
        <span class="sep">&#10022;</span>
        <span>{kicker}</span>
    </p>
    <h2>{title}</h2>
</header>

<style>
    .kicker {
        font-size: 0.7rem;
        letter-spacing: 0.4em;
        color: var(--accent);
        display: flex;
        gap: 1em;
    }

    h2 {
        font-size: clamp(2.2rem, 5vw, 3.4rem);
        font-weight: 600;
        color: var(--text);
        line-height: 1.3;
        margin-top: 0.6rem;
    }
</style>
